# Frontend env — copy to frontend/.env.local
# Only NEXT_PUBLIC_* vars are exposed to the browser.

# Where the FastAPI backend lives (used for the dev proxy + dialer WebSocket).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Supabase Auth (leave blank to run in demo mode — no login required).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# LiveKit URL for the in-browser dialer (optional; mock dialer works without it).
NEXT_PUBLIC_LIVEKIT_URL=
