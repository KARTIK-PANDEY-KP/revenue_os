# ============================================================================
# RevenueOS — Environment Configuration
# Copy to .env (backend), .env.local (frontend), and .env (trigger) as needed.
# Every integration falls back to high-quality MOCK data when its key is absent,
# so the whole product runs end-to-end before you provision a single key.
# ============================================================================

# ----------------------------------------------------------------------------
# Core LLM — Claude (Anthropic)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Tiered model routing (defaults are sensible; override if desired)
LLM_MODEL_DEEP=claude-opus-4-8          # research synthesis, architecture-level reasoning
LLM_MODEL_BALANCED=claude-sonnet-4-6    # signal extraction, personalization, scoring
LLM_MODEL_FAST=claude-haiku-4-5-20251001 # live call copilot, quick classification

# ----------------------------------------------------------------------------
# Bright Data — core web data engine
# Web MCP (search/extract/navigate) + Scraper APIs + datasets
# ----------------------------------------------------------------------------
BRIGHTDATA_API_TOKEN=
# Web MCP endpoint (hosted). Leave default unless self-hosting.
BRIGHTDATA_MCP_URL=https://mcp.brightdata.com/sse
# Web Unlocker / SERP zone names from your Bright Data dashboard
BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker
BRIGHTDATA_SERP_ZONE=serp_api
BRIGHTDATA_BROWSER_ZONE=scraping_browser

# ----------------------------------------------------------------------------
# Cognee — agent memory / knowledge graph
# Either Cognee Cloud (API key) OR a self-hosted server URL.
# ----------------------------------------------------------------------------
COGNEE_API_KEY=
COGNEE_API_URL=https://api.cognee.ai
# If self-hosting Cognee locally, point here instead (docker-compose provided):
# COGNEE_API_URL=http://localhost:8001
# Cognee uses its own LLM for graph extraction; reuse Anthropic by default.
COGNEE_LLM_PROVIDER=anthropic

# ----------------------------------------------------------------------------
# Trigger.dev — workflow / orchestration engine (TypeScript project)
# ----------------------------------------------------------------------------
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev
# The backend calls Trigger.dev tasks over HTTP using this key.
TRIGGER_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# Speechmatics — real-time speech-to-text
# ----------------------------------------------------------------------------
SPEECHMATICS_API_KEY=
SPEECHMATICS_RT_URL=wss://eu2.rt.speechmatics.com/v2

# ----------------------------------------------------------------------------
# LiveKit — real-time voice/call infrastructure
# ----------------------------------------------------------------------------
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ----------------------------------------------------------------------------
# Supabase — Postgres + Auth (provision via migrations in /supabase)
# ----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
# Direct Postgres connection string (for backend SQLAlchemy / migrations)
DATABASE_URL=

# ----------------------------------------------------------------------------
# App config
# ----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:3000
# Real sponsor providers are the DEFAULT and only path. Without keys, data
# endpoints return HTTP 503 (no demo data is ever served).
# Set this to true ONLY for offline development without keys (uses in-memory
# data + mock provider responses). Leave false in any real/judged environment.
REVENUEOS_ALLOW_MOCK=false
# Force mocks even when keys are present (offline demo of a keyed setup).
REVENUEOS_FORCE_MOCK=false
# Demo seed for the in-memory dev DB only (ignored when Supabase is configured).
REVENUEOS_LOAD_DEMO_DATA=false

# ----------------------------------------------------------------------------
# Frontend (Next.js) — NEXT_PUBLIC_* are exposed to the browser
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_LIVEKIT_URL=
